# --- Vault ---
VAULT_PATH=./vault

# --- LLM mode: 'local' (Ollama) or 'cloud' (OpenAI) ---
LLM_MODE=local

# --- Local (Ollama) ---
# qwen2.5:14b: 9GB, ~60-90s per articolo lungo. Massima compliance JSON +
# istruzioni rispetto a llama3/qwen 7b. Alternative se serve velocità:
# qwen2.5:7b (~30s, qualità buona), llama3.1:8b (~25s, JSON meno affidabile).
OLLAMA_MODEL=qwen2.5:14b
# Chat: context window e max output token. Default Ollama (2048/128) tronca
# articoli lunghi in input e taglia il recap in output.
OLLAMA_CHAT_NUM_CTX=8192
OLLAMA_CHAT_NUM_PREDICT=2048
# Embedding: usa la variante 8k creata via scripts/nomic-8k.Modelfile:
#   ollama create nomic-embed-text-8k -f scripts/nomic-8k.Modelfile
# Fallback al default (ctx 2048) se non disponibile.
OLLAMA_EMBED_MODEL=nomic-embed-text-8k
OLLAMA_EMBED_NUM_CTX=8192

# --- Cloud (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Vector DB ---
CHROMA_PATH=./vault/.chroma
PINECONE_API_KEY=
PINECONE_INDEX=second-brain

# --- Google Maps Places (optional, enables recent reviews fetch) ---
GOOGLE_MAPS_API_KEY=

# --- Google Drive PDFs (optional, enables PDF source type) ---
# Path to a service account JSON key. The SA's email must be granted
# Editor access on BOTH folder IDs below. Folders must live in My Drive
# of a user that shares them with the SA, or in a Shared Drive.
GDRIVE_CREDENTIALS_JSON=
GDRIVE_INBOX_PDF_FOLDER_ID=
GDRIVE_PROCESSED_PDF_FOLDER_ID=

# --- RSS / Atom feeds (optional, enables feed source type) ---
# JSON array of {name, url}. Default: $VAULT_PATH/.config/feeds.json
# See feeds.example.json in the repo root.
FEEDS_CONFIG_PATH=
# Per-feed recency cap: top N entries by published date are considered.
# State dedup still filters processed ones, so daily feeds normally yield
# 1 new source/run; after a weekend a Mon-run with N=3 catches Fri+Mon.
#   3 (default) → safe for typical weekday newsletters
#   1 → only the most recent (strict)
#   0 or negative → disabled (every entry the feed exposes)
FEED_MAX_ENTRIES_PER_FEED=3

# Optional date-window filter against the run's target date.
#   -1 (default) → disabled. The recency cap above already handles freshness.
#   N>=0 → require entry date in [target - N days, target]. Use for backfill.
FEED_DAYS_BACK=-1

# --- Async concurrency ---
# Max concurrent LLM/embed/HTTP ops. Default: 8 cloud, 1 local.
# Tune higher on OpenAI Tier 2+; keep at 1 with single-GPU Ollama.
ASYNC_CONCURRENCY=

# --- Embedding ---
# Max chars per chiamata embedding. Default 20000 ≈ ~6000 token, sicuro con
# nomic-embed-text-8k (ctx 8192). Per il default nomic (ctx 2048) usa 5000.
# Cloud (text-embedding-3-small) tollera 25000+.
EMBED_CHAR_LIMIT=20000

# --- Output ---
OUTPUT_LANGUAGE=italian
LOG_LEVEL=INFO
